# ============================================================================
# Device Configuration (Optional)
# ============================================================================
# Auto-detected if not set
# DEVICE=cuda #or cpu

# ============================================================================
# MinIO Configuration
# ============================================================================
MINIO_DATA_BUCKET=smart-finance-data
MINIO_MODELS_BUCKET=smart-finance-models
MINIO_RESULTS_BUCKET=smart-finance-results

MINIO_BASE_URL=https://humaine-minio-api.euprojects.net

# Optional object-key prefix inside each bucket (e.g. test, dev/alice)
# Leave empty to write directly to top-level folders.
MINIO_PREFIX=ROK_TEST

MINIO_USERNAME=your-minio-username-here
MINIO_PASSWORD=your-minio-password-here

# ============================================================================
# DuckDB Configuration
# ============================================================================
DUCKDB_PATH=storage/db/humal.duckdb

# ============================================================================
# RabbitMQ Configuration
# ============================================================================

RABBIT_URL=amqp://guest:guest@localhost:5672/
TASK_QUEUE=xai_jobs
RESULT_QUEUE=xai_results
USE_RABBITMQ=1
MESSAGE_VERSION=0.1